name: topology-tui
vms:
    - id: vm2
      memoryMB: 2048
      cpus: 1
      disk: ""
      iso: /home/powerpenguini/Downloads/alpine-virt-3.23.0-x86_64.iso
      vnc: true
      networks:
        - switch: sw1
    - id: vm3
      desiredState: running
      memoryMB: 2048
      cpus: 2
      disk: ""
      iso: /home/powerpenguini/Downloads/alpine-virt-3.23.0-x86_64.iso
      vnc: true
      networks:
        - switch: sw1
        - {}
        - {}
    - id: vm4
      memoryMB: 4096
      cpus: 2
      disk: ""
      iso: /home/powerpenguini/Downloads/alpine-virt-3.23.0-x86_64.iso
      vnc: true
      networks:
        - switch: sw1
        - {}
    - id: new
      desiredState: running
      memoryMB: 2048
      cpus: 2
      disk: ""
      vnc: true
      networks:
        - switch: sw1
    - id: ubuntu
      desiredState: running
      memoryMB: 2048
      cpus: 2
      disk: ""
      vnc: true
      networks:
        - switch: sw1
containers:
    - id: bash-test
      desiredState: running
      image: docker.io/kalilinux/kali-rolling:latest
      command:
        - /usr/bin/bash
        - -lc
        - sleep infinity
      shell: /usr/bin/bash
      networks:
        - switch: sw1
switches:
    - id: sw1
      mode: macnat-bridge
      externalLinks:
        - in2
externalLinks:
    - id: in2
      interface: wlp0s20f3
layout:
    nodes:
        bash-test:
            x: 1200
            "y": 552
        in2:
            x: 848
            "y": 96
        new:
            x: 288
            "y": 552
        sw1:
            x: 848
            "y": 336
        ubuntu:
            x: 16
            "y": 552
        vm2:
            x: 848
            "y": 552
        vm3:
            x: 560
            "y": 552
        vm4:
            x: 1520
            "y": 552
    links:
        - from:
            type: switch
            id: sw1
          to:
            type: vm
            id: vm2
        - from:
            type: external
            id: in2
          to:
            type: switch
            id: sw1
        - from:
            type: vm
            id: vm3
          to:
            type: switch
            id: sw1
        - from:
            type: switch
            id: sw1
          to:
            type: vm
            id: vm4
        - from:
            type: switch
            id: sw1
          to:
            type: container
            id: bash-test
        - from:
            type: switch
            id: sw1
          to:
            type: vm
            id: ubuntu
